{
  "name": "floppycloud",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter app dev",
    "dev:all": "concurrently \"pnpm --filter worker dev\" \"pnpm --filter app dev\"",
    "worker:deploy": "pnpm --filter worker deploy",
    "build": "pnpm --filter app build && pnpm --filter worker build",
    "deploy": "pnpm --filter worker deploy && pnpm --filter app deploy",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}